// CJC Animation Portal — data model
// Local dev uses SQLite. To move to Supabase/Postgres later, change
// `provider` to "postgresql" and point DATABASE_URL at the Supabase connection string.

generator client {
  provider = "prisma-client-js"
  // "native" for local dev (Windows); "rhel-openssl-3.0.x" for Vercel's serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("member") // "admin" | "member"
  createdAt    DateTime @default(now())

  sessions Session[]
  projects Project[]
  episodes Episode[]
  comments Comment[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  episodes Episode[]

  @@index([createdById])
}

model Episode {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  // local storage: filename under /storage. In production this becomes a Mux asset id.
  videoFile   String?
  mimeType    String?
  durationMs  Int?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  comments Comment[]

  @@index([projectId])
}

model Comment {
  id         String   @id @default(cuid())
  episodeId  String
  episode    Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  body       String
  // pinned point in the video, in milliseconds. Null for a reply.
  timecodeMs Int?
  // annotated frame grabbed at the pinned moment (PNG in storage). Doubles as the AI start-frame.
  frameImage String?
  // cached Higgsfield-format prompt generated by Claude from this note + frame.
  generatedPrompt String?
  parentId   String?
  parent     Comment? @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("Thread")
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([episodeId])
  @@index([parentId])
}
